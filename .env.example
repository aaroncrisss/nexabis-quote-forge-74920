# NEXABIS Quote Forge - Environment Variables
# Copy this file to .env and fill in the values

# Supabase Connection (Required)
VITE_SUPABASE_URL=https://supabase.nexabistech.com
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key-here
VITE_SUPABASE_PROJECT_ID=your-supabase-project-id-here

# Deploy Configuration (Optional - can also be set as system env vars)
# NEXABIS_VPS_IP=your-vps-ip-here
